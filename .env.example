# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@db:5432/warikan_drive
# For local backend (outside Docker): postgresql://postgres:postgres@localhost:5432/warikan_drive

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
AUTH_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Google Maps（フロント: 地図・住所オートコンプリート / バック: 経路検索）
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# フロントで地図・Places を使う場合は同じキーを NEXT_PUBLIC_ で渡す
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
